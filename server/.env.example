# Copy this file to ".env" (same folder) and fill in your real key.
# Get a key at https://console.anthropic.com/ after adding billing/credits.
ANTHROPIC_API_KEY=your-key-here

# Optional: port the local server runs on.
PORT=3001

# Optional soft monthly spend cap in USD shown/enforced in the dashboard UI.
# This does not limit anything on Anthropic's side -- it's just a UI warning.
MONTHLY_CAP_USD=15

# --- Instagram (optional, only needed for Sync from Instagram / Publish Reel) ---
# See INSTAGRAM-SETUP.md for how to get these.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=

# --- Cloudinary (needed for Publish Reel / Upload+Schedule -- hosts the video
# so Instagram's API can fetch it, and so the browser can upload directly
# without routing large video files through this server). Free account at
# https://cloudinary.com/. See INSTAGRAM-SETUP.md for exact steps.
# CLOUDINARY_CLOUD_NAME is on your Cloudinary dashboard home page.
# CLOUDINARY_UPLOAD_PRESET is a preset YOU create (Settings -> Upload ->
# Upload presets -> Add upload preset -> Signing Mode: "Unsigned"). Use its
# preset name here -- not a secret, it's meant to be used from the browser.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# --- Supabase (needed for data to persist across devices/redeploys, and for
# scheduling/trial-posting reels). See SUPABASE-SETUP.md.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron auth (recommended once deployed -- prevents randoms from hitting
# your scheduler endpoint). Any random string; put the same value in the
# Vercel Cron / external pinger config as ?secret=... See VERCEL-SETUP.md.
CRON_SECRET=

# --- Login (required -- gates the whole dashboard). Any random string,
# e.g. `openssl rand -hex 32`. Signs the login session cookie; changing this
# value logs everyone out. Two accounts are seeded via `node server/seedUsers.js`
# once the `users` table exists (server/supabase-schema.sql) -- see SUPABASE-SETUP.md.
SESSION_SECRET=
